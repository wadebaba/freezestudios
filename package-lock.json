<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Forum — FreezeMC</title>
<meta name="description" content="FreezeMC forum: duyurular, genel sohbet, faction ilanları ve destek talepleri.">
<link rel="stylesheet" href="/css/main.css">
<link rel="stylesheet" href="/css/pages.css">
</head>
<body>

<%- include('partials/header', { active: 'forum' }) %>

<section class="page-hero">
  <div class="wrap">
    <div class="breadcrumb">FREEZEMC <span class="sep">/</span> <span class="current">Forum</span></div>
    <h1>Forum</h1>
    <p>Duyurular, faction ilanları, destek talepleri ve topluluk sohbeti — hepsi burada.</p>
  </div>
</section>

<section class="section">
  <div class="wrap">

    <div class="forum-toolbar">
      <div class="forum-search">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <input type="text" placeholder="Konu ara...">
      </div>
      <a href="#" class="btn btn-primary btn-sm">+ Yeni Konu Aç</a>
    </div>

    <div class="category-grid">
      <% forum.categories.forEach(function(c) { %>
        <a href="#" class="category-card">
          <span class="cicon"><%- forumIcon(c.icon) %></span>
          <div>
            <div class="cname"><%= c.name %></div>
            <div class="cdesc"><%= c.desc %></div>
          </div>
          <div class="ccount"><%= c.count %><br>konu</div>
        </a>
      <% }) %>
    </div>

    <div class="section-head" style="margin-bottom:24px;">
      <span class="eyebrow">Güncel</span>
      <h2 style="font-size:24px;">Son konular</h2>
    </div>

    <div class="thread-list">
      <% forum.threads.forEach(function(t) { %>
        <div class="thread-row">
          <span class="thread-tag tag-<%= t.tag %>"><%= t.tagLabel %></span>
          <div>
            <div class="thread-title"><%= t.title %></div>
            <div class="thread-meta"><%= t.author %><%= t.time ? ' · ' + t.time : '' %></div>
          </div>
          <div></div>
          <div class="thread-replies"><%= t.replies %><span>yanıt</span></div>
        </div>
      <% }) %>
    </div>

  </div>
</section>

<section class="cta-band">
  <div class="wrap">
    <h2>Topluluğa katılmaya hazır mısın?</h2>
    <p>Forumda konu açmak için bir hesap oluştur, ya da hızlıca Discord'a katıl.</p>
    <div class="cta-actions">
      <a href="#" class="btn btn-primary">Hesap Oluştur</a>
      <a href="<%= site.discordUrl %>" class="btn btn-ghost">Discord'a Katıl</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
