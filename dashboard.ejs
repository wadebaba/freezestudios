/* ===========================================================
   FREEZEMC ADMIN — Panel styles
   =========================================================== */

.admin-body { background: var(--night); min-height: 100vh; }

.admin-shell {
  display: grid;
  grid-template-columns: 240px 1fr;
  min-height: 100vh;
}

.admin-sidebar {
  background: var(--panel);
  border-right: 1px solid var(--border);
  padding: 28px 22px;
  display: flex;
  flex-direction: column;
  position: sticky;
  top: 0;
  height: 100vh;
}

.admin-nav {
  display: flex;
  flex-direction: column;
  gap: 4px;
  flex: 1;
}

.admin-nav-link {
  padding: 11px 14px;
  border-radius: var(--radius);
  font-size: 14px;
  font-weight: 600;
  color: var(--steel);
  transition: background 0.15s ease, color 0.15s ease;
}

.admin-nav-link:hover { background: var(--panel-2); color: var(--frost); }

.admin-nav-link.active {
  background: rgba(61, 217, 240, 0.1);
  color: var(--ice);
}

.admin-sidebar-bottom { margin-top: auto; }

.admin-main {
  padding: 40px 48px 100px;
  max-width: 920px;
}

.admin-tab { display: none; }
.admin-tab.active { display: block; }

.admin-header { margin-bottom: 32px; }
.admin-header h2 { font-size: 26px; margin-bottom: 6px; }
.admin-header p { font-size: 14px; }

.admin-card {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 24px;
  margin-bottom: 22px;
}

.admin-card h3 {
  font-family: var(--font-body);
  font-size: 15px;
  font-weight: 700;
  color: var(--frost);
  margin-bottom: 18px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--border);
}

.field { margin-bottom: 16px; }
.field:last-child { margin-bottom: 0; }

.field label {
  display: block;
  font-size: 13px;
  font-weight: 600;
  color: var(--steel);
  margin-bottom: 7px;
}

input[type="text"], input[type="number"], input[type="password"], textarea, select {
  width: 100%;
  background: var(--night);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 11px 13px;
  color: var(--frost);
  font-family: var(--font-body);
  font-size: 14px;
  outline: none;
  transition: border-color 0.15s ease;
  resize: vertical;
}

input:focus, textarea:focus, select:focus { border-color: var(--ice); }

select { cursor: pointer; }

.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 16px; }
.grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; }

.grid-2 input, .grid-2 textarea, .grid-2 select,
.grid-3 input, .grid-3 textarea, .grid-3 select { margin: 0; }

@media (max-width: 760px) {
  .grid-2, .grid-3 { grid-template-columns: 1fr; }
}

.repeat-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 14px; }

.repeat-row {
  display: flex;
  gap: 10px;
  align-items: center;
}

.repeat-row input { margin: 0; }
.repeat-row .w-sm { max-width: 110px; flex-shrink: 0; }

.repeat-block-list { display: flex; flex-direction: column; gap: 16px; margin-bottom: 14px; }

.repeat-block {
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 18px;
  background: var(--panel-2);
}

.repeat-block-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14px;
  font-size: 13px;
  font-weight: 700;
  color: var(--ice);
  font-family: var(--font-mono);
}

.btn-icon-del {
  background: rgba(240, 85, 61, 0.1);
  border: 1px solid rgba(240, 85, 61, 0.25);
  color: var(--danger);
  border-radius: 4px;
  width: 26px;
  height: 26px;
  font-size: 13px;
  cursor: pointer;
  flex-shrink: 0;
  transition: background 0.15s ease;
}

.btn-icon-del:hover { background: rgba(240, 85, 61, 0.2); }

.checkbox-label {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: var(--steel);
  font-weight: 600;
  cursor: pointer;
}

.checkbox-label input { width: auto; }

.admin-save {
  margin-top: 8px;
  position: sticky;
  bottom: 24px;
}

.rule-section-block { border-left: 3px solid var(--ice-dim); }
.rule-item-block { border-left: 2px solid var(--border); }

/* Toast */
.toast {
  position: fixed;
  top: 24px;
  right: 24px;
  background: var(--panel);
  border: 1px solid var(--ice);
  color: var(--frost);
  padding: 14px 20px;
  border-radius: var(--radius);
  font-size: 14px;
  font-weight: 600;
  box-shadow: 0 10px 30px -10px rgba(0,0,0,0.5);
  opacity: 0;
  transform: translateY(-10px);
  transition: opacity 0.25s ease, transform 0.25s ease;
  pointer-events: none;
  z-index: 200;
}

.toast.show { opacity: 1; transform: translateY(0); }
.toast.error { border-color: var(--danger); color: var(--danger); }

@media (max-width: 860px) {
  .admin-shell { grid-template-columns: 1fr; }
  .admin-sidebar { position: static; height: auto; flex-direction: row; align-items: center; flex-wrap: wrap; }
  .admin-nav { flex-direction: row; flex-wrap: wrap; }
  .admin-sidebar-bottom { margin-top: 0; margin-left: auto; display: flex; gap: 8px; }
  .admin-main { padding: 28px 20px 80px; }
}
